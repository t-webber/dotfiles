#!/bin/sh

if [ -z "$1" ]; then
	echo "Usage: nix file[.c]"
	exit
fi

cwd="$(pwd)"

ext="$(echo "$1" | rev | cut -c1-2 | rev)"

cd "$CMD"

if [ "$ext" = ".c" ]; then
	cd src
	printf "int main(int argc, const char *const *const argv) {}" >>"$1"
	$EDITOR "$1"
else
	cd sh
	printf "#!/bin/sh\n\n" >>"$1"
	chmod +x "$1"
	$EDITOR "$1"
fi

cd "$cwd"
