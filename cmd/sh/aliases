cup="/usr/bin/make -C $CMD/src --no-print-directory"
_al cup "$cup release"
_al cupc "$cup clean release"
_al cupd "$cup debug"

_al zh "s $SECRET/bash_history"
_al zhh "zh | gv '^#'"
_al zhvban "zhh | gv '$_banned'"

_al de 'declare -f'

_ual gpt raw
_al raw "fix && PS1='$ ' && PROMPT_COMMAND='' && builtin unalias -a && builtin alias z='. /etc/bash.bashrc'"

_al mboot 'm /dev/nvme0n1p1 /boot'
_ual mkinitcpio mkcp
_al mkcp 'sd /bin/mkinitcpio -P'

_ual mnt m
_ual mount m
_ual make m
_ual mk m
_ual man m
_ual mn m

_al ti time
_al hf "$CARGO_HOME/bin/hyperfine"
_ual hyperfine hf

_al path 'eh $PATH'
_al wi '. wi'
_ual whereis wi
_ual which wi

_ual date "dt, dtl, dth"
_al dt /bin/date
_al dtl 'eh [$(dt "+%Y/%m/%d %H:%M:%S:%N")]'
_al hour "dt '+%H:%M:%S'"

_al mitapache "cp $CMD/data/LICENSE-MIT . && cp $CMD/data/LICENSE-APACHE ."
_al mit "cp $CMD/data/LICENSE-MIT ."
_al vimsh "$DEV/vsh/main.out"
_al secret ". $FILES/.secret/vars"
_al ling '/home/b/.files/.data/local/share/gem/ruby/3.4.0/bin/github-linguist'
_al scope '/home/b/.files/.apps/telescope.nvim'

_al ChkTeX chktex
_al qr qrencode
_al notif dunstify
_al gpg-list 'gpg --list-secret-keys --keyid-format=long'
_al cols 'tput cols'
_al rand 'openssl rand -base64 255'
_al codex 'code --install-extension'
_al fix 'stty sane; builtin cd; ehen "\033[0m"'
_al cls 'ehen "\033c"'
_al nt numbat
_al md 'gh markdown-preview'
_al tf trufflehog
_al qa qalc

wasted=".config .config/* .local .local/* .pki .pki/* .cache .cache/*"
_al clean "h; sv $wasted; rn $wasted"
_al wr 'curl wttr.in'

_al slp sleep

_al alac '/usr/bin/open -n -a alacritty'

_ual random-json rdj
_al rdj "$CARGO_HOME/bin/random-json"

_ual sort-rust-array sra
_al sra "$CARGO_HOME/bin/sort-rust-array"

_al mls "make -qp | awk -F':' '/^[a-zA-Z0-9][^$#\/\t=]*:([^=]|$)/ {split(\$1,A,/ /);for(i in A)print A[i]}' | sort -u"
_al ltx pdflatex

_al gx2 "gx | uc | gv '^\s*1'"

_al adbl 'adb shell pm list packages'
_al adbu 'adb uninstall --user 0'
_al adbd 'adb shell pm disable-user --user 0'

_ual floaterm ft
_ual joplin jp
_al jp "/bin/joplin --profile $XDG_CONFIG_HOME/joplin"

