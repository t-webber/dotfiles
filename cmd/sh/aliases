###############################
### ALIAS DEFINITION HELPER ###
###############################

_sections=
_print_sections() { al "$1" "ehen '$_sections'"; }

_buff=
_flush() { _buff=; }
_sep() { _buff="$_buff\n"; }
_print() {
	al "$1" "ehen '$_buff'" !
	_sections="$_sections$1\t$2\n"
}

al() {
	local dest=
	local comment=

	if [ "$2" = '-p' ]; then
		dest="cls && $3 $4"
		if [ -z "$5" ]; then
			comment="$4"
		else if [ "$5" != '!' ]; then
			comment="> $5"
		fi; fi

	else
		dest="$2"
		if [ -z "$3" ]; then
			comment="$2"
		else if [ "$3" != '!' ]; then
			comment="> $3"
		fi; fi
	fi

	alias "$1"="$dest"

	if [ -z "$comment" ]; then
		:
	else
		_buff="$_buff$1\t$comment\n"
	fi
}

_ual() { alias "$1"="eh use $2"; }
_uall() { alias "$1"="eh use alias for $1"; }

