al() {
	if [ -z "$1" ]; then
		/bin/echo "Missing 1!."
		return 1
	fi
	if [ -z "$2" ]; then
		/bin/echo "Missing 2!."
		return 2
	fi

	local l="$LOGS/aliases"
	local name=$1
	shift
	eval "$name() { 
		/bin/echo $name >> $l
		$* \$@
