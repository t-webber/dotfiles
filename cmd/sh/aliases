###############################
### ALIAS DEFINITION HELPER ###
###############################

incr() {
        local var="$1"
        eval "$var=\$(( $var + 1 ))"
}

_sections=
_print_sections() { _al "$1" "ehen '$_sections'"; }

_buff=
_flush() { _buff=; }
_sep() { _buff="$_buff\n"; }
_print() {
        _al "$1" "cls && ehen '$_buff'" !
        _sections="$_sections$1\t$2\n"
}

_buffappend() {
        _buff="$_buff$1\t$2\n"
}

_al() {
        if [ "$2" = '-p' ]; then
                local dest="$3 $4"
                if [ -z "$5" ]; then
                        local comment="$4"
                else if [ "$5" != '!' ]; then
                        local comment="> $5"
                fi; fi

        else
                local dest="$2"
                if [ -z "$3" ]; then
                        local comment="$2"
                else if [ "$3" != '!' ]; then
                        local comment="> $3"
                fi; fi
        fi

        alias "$1"="$dest"

        if [ -n "$comment" ]; then
                _buffappend "$1" "$comment"
        fi
}

_banned=""

_ual() {
        _al "$1" "echo use $2"
        _banned="$_banned|$1"
}

_uall() {
        _al "$1" "echo use alias for $1"
        _banned="$_banned|$1"
}

_dal() {
        if [ "$2" = '-p' ]; then
                _al "$1" -p "$3" "$4" !
                local start=5
                local name="$4"
        else
                _al "$1" "$2" !
                local start=3
                local name="$2"
        fi

        _arg() {
                if [ "${#1}" = "1" ]; then
                        printf "%s\n" "-$1"
                else
                        printf "%s\n" "--$1"
                fi
        }

        _abbr() { echo "${1:0:1}"; }

        _inner() {
                if [ "$2" = "-p" ]; then
                        _al "$1$5" -p "$3" "$4 $6" !
                else
                        _al "$1$5" "$2 $6" !
                fi
        }

        local argv=("${@:$start}")
        local n=${#argv[@]}
        local max=$((1 << n))

        local display_args=""

        for ((mask = 0; mask < max; mask++)); do
                local abbrs=""
                local args=""

                for ((idx = 0; idx < n; idx++)); do
                        if ((mask & (1 << idx))); then
                                continue
                        fi

                        local arg=${argv[idx]}

                        abbrs="$abbrs$(_abbr $arg)"
                        args="$args $(_arg $arg)"
                        _inner "$1" "$2" "$3" "$4" "$abbrs" "$args"
                done
        done

        for ((idx = 0; idx < n; idx++)); do
                display_args="$display_args[${argv[idx]}] "
        done

        _buffappend "$1" "$name $display_args"
}

