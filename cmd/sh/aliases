##############
### PRISMA ###
##############

pam() {
	alias zwx="$b x prisma migrate"
 	case "$1" in 
		r|reset) 	zwx reset 	"${@:2}" ;;
		v|resolve)	zwx resolve 	"${@:2}" ;;
		s|status) 	zwx status 	"${@:2}" ;; 
		d|deploy) 	zwx deploy 	"${@:2}" ;;
		+) 		zwx dev --name $1 "${@:2}";;
		*) printf "pam r: reset\npam s: status\npam d: deploy\npam <name> dev --name <name>\n";;
	esac
}

pa() {
	alias zw="$b x prisma"
	case "$1" in
		o|studio)	zw studio 	"${@:2}";;
		i|init)		zw init 	"${@:2}";;
		g|gen|generate)	zw generate 	"${@:2}";;
		pl|pull)	zw db pull 	"${@:2}";;
		s|seed)		zw db seed 	"${@:2}";;
		ph|push)	zw db push 	"${@:2}";;
		v|validate) 	zw validate 	"${@:2}";;
		m|migrate)	printf "use pam";;
		*) printf "pa o: studio\npa i: init\npa g: generate\npa pl: db pull\npa psh: db push\npa s: db seed\npa v: validate\n";;
	esac
}

