#!/bin/bash

sl=$SLOGS/gui_startup

sxhkd &>$sl-sxhkd &

setxkbmap fr &

xmodmap -e "clear Mod5"
xmodmap -e "add Mod3 = ISO_Level3_Shift"
# xrandr --output eDP-1 --scale 1.5x1.5

xsetwacom set 12 Button 1 "key +Control_L +z -z"

dunst &
clipcatd &

lht set 150

sleep 2

brave --no-startup-window &>$sl-brave &
vl start &>$sl-vl &

sleep 2
pkill chrome_crashpad
