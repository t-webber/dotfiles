if [ "$DEVICE" = "acer" ]; then
	mountpoint -q /boot || mboot
fi
lsblk

sd rmm -rf "$FILES/.waste"
n "$FILES/.waste/"

"$ETC/link.sh"

while ! ping -c1 -W1 1.1.1.1; do
	sleep 1
done

bur | gv Downloading &

